{
  "name": "openjud-backend",
  "version": "1.0.0",
  "description": "Backend for OpenJud - DataJud API Consumer",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "ts-node": {
    "esm": true,
    "experimentalEsm": true
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/cors": "^2.8.16",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@tsconfig/node20": "^20.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
